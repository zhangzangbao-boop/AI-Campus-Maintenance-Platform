# ========================================
# AI Campus Maintenance Platform - Environment Variables Template
# ========================================
#
# IMPORTANT: Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to Git!
#
# If any API keys were previously committed to the repository, they are
# considered compromised. Please revoke them in the respective platforms
# and generate new keys.
#
# ========================================

# Nacos Service Discovery
NACOS_SERVER_ADDR=127.0.0.1:8848

# Database Configuration
DB_URL=jdbc:mysql://127.0.0.1:3306/repairdb?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=

# JWT Authentication
# WARNING: Generate a strong secret for production (at least 256 bits)
JWT_SECRET=
JWT_EXPIRATION_MS=604800000

# AI Service Configuration
# Set AI_ENABLED=false if you don't have an API key
AI_ENABLED=false
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
AI_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=20