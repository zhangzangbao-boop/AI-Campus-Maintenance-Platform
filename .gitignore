# ========================================
# AI Campus Maintenance Platform - Git Ignore
# ========================================

# Environment Variables (IMPORTANT: Never commit real secrets!)
.env
.env.*
!.env.example

# Local secret configurations
application-local.yml
application-secret.yml
**/application-local.yml
**/application-secret.yml

# ========================================
# Backend (Java/Maven)
# ========================================
backend/target/
backend/.idea/
backend/*.iml
backend/*.log
backend/backups/
backend/logs/

smart-backend/**/target/
smart-backend/**/backups/
smart-backend/**/*.log
smart-backend/**/logs/

# ========================================
# Frontend (React/Node)
# ========================================
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

smart-frontend/node_modules/
smart-frontend/dist/
smart-frontend/.env
smart-frontend/.env.local
smart-frontend/.env.development.local
smart-frontend/.env.test.local
smart-frontend/.env.production.local
smart-frontend/npm-debug.log*
smart-frontend/yarn-debug.log*
smart-frontend/yarn-error.log*

# ========================================
# IDE
# ========================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ========================================
# OS Generated Files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ========================================
# Logs
# ========================================
*.log
logs/
**/logs/

# ========================================
