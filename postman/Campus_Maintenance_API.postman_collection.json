    {
      "name": "02-报修工单",
      "item": [
        {
          "name": "创建报修工单",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.ticketId) {",
                  "        pm.collectionVariables.set('ticketId', response.data.ticketId);",
                  "        console.log('工单ID已保存:', response.data.ticketId);",
                  "    }",
                  "}",
                  "",
                  "pm.test('状态码应为201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('响应应包含工单ID', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.ticketId).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "categoryId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "locationText",
                  "value": "测试地点-宿舍楼A栋101",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "测试报修-水龙头漏水",
                  "type": "text"
                },
                {
                  "key": "priority",
                  "value": "medium",
                  "type": "text",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/repair-orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "repair-orders"]
            }
          },
          "response": []
        },
        {
          "name": "获取我的工单列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/repair-orders/my?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "repair-orders", "my"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
