# ===========================================
# 启云校园智慧维修平台 - 前端环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填写实际值

# API 网关地址（必填）
# 开发环境示例：http://localhost:8070/api
# 生产环境示例：https://api.example.com/api
VITE_API_BASE_URL=http://localhost:8070/api

# WebSocket 网关地址（必填）
# 开发环境示例：ws://localhost:8070/ws
# 生产环境示例：wss://api.example.com/ws
VITE_WS_URL=ws://localhost:8070/ws